# ============================================================
# SouqStore — Dokploy production environment
# Copy these into the Dokploy service "Environment" tab (or a .env).
# CHANGE every secret before going live.
# ============================================================

# --- your domain (DNS A-record must point at the Dokploy server) ---
DOMAIN=souqstore.example.com

# --- secrets (generate: openssl rand -hex 32) ---
DJANGO_SECRET_KEY=CHANGE_ME_super_secret_key
JWT_SIGNING_KEY=CHANGE_ME_shared_jwt_key

TZ=Africa/Cairo

# --- databases ---
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=CHANGE_ME_auth_pw

VENDOR_DB_NAME=vendor_db
VENDOR_DB_USER=vendor_user
VENDOR_DB_PASSWORD=CHANGE_ME_vendor_pw

CATALOG_DB_NAME=catalog_db
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=CHANGE_ME_catalog_pw

# --- message broker ---
RABBITMQ_DEFAULT_USER=souq
RABBITMQ_DEFAULT_PASS=CHANGE_ME_rabbit_pw
