# ============================================================
# SouqStore — root environment for docker compose
# Copy to `.env` and adjust before running `docker compose up`.
# ============================================================

# --- Django / shared ---
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-insecure-change-me-in-production
JWT_SIGNING_KEY=dev-shared-jwt-key-change-me
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
TZ=Africa/Cairo

# --- Auth service database ---
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass

# --- Vendor service database ---
VENDOR_DB_NAME=vendor_db
VENDOR_DB_USER=vendor_user
VENDOR_DB_PASSWORD=vendor_pass

# --- Catalog service database ---
CATALOG_DB_NAME=catalog_db
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=catalog_pass

# --- Shared infra ---
RABBITMQ_DEFAULT_USER=souq
RABBITMQ_DEFAULT_PASS=souq_pass
MINIO_ROOT_USER=souq
MINIO_ROOT_PASSWORD=souq_secret123
